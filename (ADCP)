def professional_cleaner(input_file):
    """The main logic that cleans and analyzes the data"""
    
    if not os.path.exists(input_file):
        log_message(f"Error: {input_file} not found!")
        return

    log_message(f"Loading data from {input_file}...")
    df = pd.read_csv(input_file)

    # 1. REMOVE DUPLICATES
    # Clients hate double-counting sales.
    initial_count = len(df)
    df.drop_duplicates(inplace=True)
    log_message(f"Removed {initial_count - len(df)} duplicate rows.")

    # 2. STRING CLEANING
    # Fixes ' Keyboard ' (with spaces) to 'Keyboard'
    log_message("Trimming whitespace from text columns...")
    df['Product'] = df['Product'].str.strip()

    # 3. FIXING DATA TYPES (The 'Math' part)
    # Converts Price to numbers, turns errors into 'NaN'
    log_message("Converting Price column to numeric...")
    df['Price'] = pd.to_numeric(df['Price'], errors='coerce')
    
    # 4. HANDLING MISSING VALUES
    # Filling missing Quantities with 1 (standard assumption)
    # Filling missing Prices with the average (mean)
    log_message("Filling missing values...")
    df['Quantity'] = df['Quantity'].fillna(1)
    df['Price'] = df['Price'].fillna(df['Price'].mean())

    # 5. DATE STANDARDIZATION
    # Clients often have dates in 5 different formats. This fixes them all.
    log_message("Standardizing date formats...")
    df['Date'] = pd.to_datetime(df['Date'], errors='coerce', dayfirst=False)

    # 6. FEATURE ENGINEERING
    # Calculating total revenue per row
    log_message("Calculating Total Revenue per item...")
    df['Total_Revenue'] = df['Price'] * df['Quantity']

    # 7. DATA ANALYTICS SUMMARY
    # This is what the client actually pays for.
    log_message("Generating summary statistics...")
    summary = {
        'Total Revenue': df['Total_Revenue'].sum(),
        'Average Order Value': df['Total_Revenue'].mean(),
        'Top Product': df.groupby('Product')['Total_Revenue'].sum().idxmax(),
        'Items Sold': df['Quantity'].sum()
    }

    # 8. EXPORTING THE RESULTS
    output_name = 'clean_sales_report.csv'
    df.to_csv(output_name, index=False)
    
    # Printing the final report for the user
    print("\n" + "="*30)
    print("      SALES REPORT      ")
    print("="*30)
    for key, value in summary.items():
        print(f"{key}: {value:.2f}" if isinstance(value, float) else f"{key}: {value}")
    print("="*30)
    log_message(f"Success! Cleaned data saved as {output_name}")

